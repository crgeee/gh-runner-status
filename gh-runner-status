repl_help() {
  cat <<'EOF'
Dashboard keys (single keystroke, no Enter):
  r           Refresh now (instead of waiting for the timer)
  c           Command mode — type any command, then [Enter]
  a           Quick "add OWNER/REPO" — same as c with `add ` pre-filled
  h, ?        This help
  q, Ctrl-D   Quit

Commands you can type in command mode (`c` then a line):
  list, status         Show runner status table
  local                Runners on this machine + per-runner metrics
  start NAME           Start a local runner
  stop NAME            Stop a local runner
  restart NAME         Restart a local runner
  logs NAME            Tail recent logs
  info NAME            Detailed view of one runner
  update [--check] [NAME]
                       Upgrade a runner to the latest version. Without
                       NAME, prints a fleet-wide outdated report.
  doctor               Health check across all local runners
  watch [SECONDS]      Auto-refresh interval (default 30s)
  notify               Send Telegram alert if any runner is offline
  add OWNER/REPO       Get registration token + setup instructions
  remove OWNER/REPO N  Deregister a runner from the repo
  stats                Aggregate fleet view
  help                 This help
  quit                 Exit

Aliases: l/ls=list · r=restart · s=start · x=stop · n=notify ·
         w=watch · a=add

Tip: bare `gh runner-status` opens the dashboard. Pass any subcommand
to run one-shot from your shell (e.g. `gh runner-status doctor`).
EOF
}

# Theme palette. Override with GH_RUNNER_STATUS_THEME=light|dark|neon
# (default: dark). Each theme is a set of ANSI color escapes the
# renderers consume — keeps color choices in one place.
_theme_init() {
  local theme="${GH_RUNNER_STATUS_THEME:-dark}"
  case "$theme" in
    light)
      # Lighter terminals: avoid dim-grey on white bg (unreadable).
      # Use bold + standard colors with darker accents.
      THEME_BANNER=$'\033[1;34m'      # bold blue
      THEME_BANNER_META=$'\033[34m'   # blue
      THEME_PROMPT=$'\033[1;35m'      # bold magenta
      THEME_HOTKEY=$'\033[1;33m'      # bold yellow
      THEME_HOTKEY_LBL=$'\033[33m'    # yellow
      THEME_OK=$'\033[1;32m'          # bold green
      THEME_WARN=$'\033[1;33m'        # bold yellow
      THEME_ERR=$'\033[1;31m'         # bold red
      THEME_DIM=$'\033[2;90m'         # dim grey (subtle)
      THEME_RULE=$'\033[34m'          # blue
      THEME_RESET=$'\033[0m'
      ;;
    neon)
      # High-contrast popping colors. Looks great on a dark bg.
      THEME_BANNER=$'\033[1;38;5;201m'   # hot pink
      THEME_BANNER_META=$'\033[38;5;213m' # lighter pink
      THEME_PROMPT=$'\033[1;38;5;51m'    # bright cyan
      THEME_HOTKEY=$'\033[1;38;5;226m'   # bright yellow
      THEME_HOTKEY_LBL=$'\033[38;5;220m' # gold
      THEME_OK=$'\033[1;38;5;46m'        # vivid green
      THEME_WARN=$'\033[1;38;5;214m'     # orange
      THEME_ERR=$'\033[1;38;5;196m'      # vivid red
      THEME_DIM=$'\033[38;5;240m'        # mid grey
      THEME_RULE=$'\033[38;5;141m'       # purple
      THEME_RESET=$'\033[0m'
      ;;
    dark|*)
      # Default: dark terminal, bright text. Still pops without being
      # garish. Bright variants of the standard 8 colors.
      THEME_BANNER=$'\033[1;96m'         # bright cyan, bold
      THEME_BANNER_META=$'\033[96m'      # bright cyan
      THEME_PROMPT=$'\033[1;96m'         # bright cyan, bold
      THEME_HOTKEY=$'\033[1;93m'         # bright yellow, bold
      THEME_HOTKEY_LBL=$'\033[37m'       # white
      THEME_OK=$'\033[1;92m'             # bright green
      THEME_WARN=$'\033[1;93m'           # bright yellow
      THEME_ERR=$'\033[1;91m'            # bright red
      THEME_DIM=$'\033[2;37m'            # dim grey
      THEME_RULE=$'\033[2;36m'           # dim cyan
      THEME_RESET=$'\033[0m'
      ;;
  esac
}

# Initialize once on script load so the env-var check happens early.
_theme_init

render_repl_banner() {
  local has_color="$1"
  local short_host
  short_host=${HOSTNAME%%.*}
  [[ -z "$short_host" ]] && short_host=$(hostname 2>/dev/null || echo "")
  local now
  now=$(date '+%H:%M:%S')
  if [[ $has_color -eq 1 ]]; then
    printf '%s▸ gh-runner-status%s %sv%s%s %s•%s %s%s%s %s•%s %s%s%s\n' \
      "$THEME_BANNER" "$THEME_RESET" \
      "$THEME_BANNER_META" "$VERSION" "$THEME_RESET" \
      "$THEME_DIM" "$THEME_RESET" \
      "$THEME_BANNER_META" "${short_host:-localhost}" "$THEME_RESET" \
      "$THEME_DIM" "$THEME_RESET" \
      "$THEME_BANNER_META" "$now" "$THEME_RESET"
  else
    printf 'gh-runner-status v%s • %s • %s\n' "$VERSION" "${short_host:-localhost}" "$now"
  fi
}

render_repl_footer() {
  local has_color="$1"
  local refresh="${2:-30}"
  if [[ $has_color -eq 1 ]]; then
    # Each [key] is bright; the label after it is dimmer so the
    # hotkey itself "pops" without making the whole line shouty.
    printf '%s─ refreshing every %ss • %s' "$THEME_RULE" "$refresh" "$THEME_RESET"
    printf '%s[r]%s%sefresh %s' "$THEME_HOTKEY" "$THEME_RESET" "$THEME_HOTKEY_LBL" "$THEME_RESET"
    printf '%s[c]%s%sommand %s' "$THEME_HOTKEY" "$THEME_RESET" "$THEME_HOTKEY_LBL" "$THEME_RESET"
    printf '%s[a]%s%sdd %s'     "$THEME_HOTKEY" "$THEME_RESET" "$THEME_HOTKEY_LBL" "$THEME_RESET"
    printf '%s[h]%s%selp %s'    "$THEME_HOTKEY" "$THEME_RESET" "$THEME_HOTKEY_LBL" "$THEME_RESET"
    printf '%s[q]%s%suit%s\n'   "$THEME_HOTKEY" "$THEME_RESET" "$THEME_HOTKEY_LBL" "$THEME_RESET"
  else
    printf -- '- refreshing every %ss • [r]efresh [c]ommand [a]dd [h]elp [q]uit\n' "$refresh"
  fi
}

# Render the active dashboard: banner, status table, footer. Used on
# REPL entry and on /clear so the user always has live state visible
# rather than a blank prompt.
# Pull the current rows once and stash them in DASHBOARD_ROWS_CACHE,
# along with DASHBOARD_CACHE_STATUS so the renderer can distinguish:
#   ok           — rows ready to display (may be empty if no runners)
#   no_config    — config file missing or empty
#   fetch_error  — fetch attempted but failed (bad token, network down)
# Called by the dashboard loop on first paint, on timer expiry, and on
# explicit [r]efresh. Post-command redraws use the cache (no API call)
# so they're instant.
_dashboard_refresh_cache() {
  local cfg="${CONFIG_FILE:-$(config_path)}"
  DASHBOARD_CACHE_AT=$SECONDS
  if [[ ! -f "$cfg" || ! -s "$cfg" ]]; then
    DASHBOARD_ROWS_CACHE=""
    DASHBOARD_CACHE_STATUS="no_config"
    return 0
  fi
  local repos=()
  while IFS= read -r r; do
    [[ -n "$r" ]] && repos+=("$r")
  done < <(read_config_optional "$cfg")
  if [[ ${#repos[@]} -eq 0 ]]; then
    DASHBOARD_ROWS_CACHE=""
    DASHBOARD_CACHE_STATUS="no_config"
    return 0
  fi
  if DASHBOARD_ROWS_CACHE=$(collect_remote_runners "${repos[@]}" 2>&1); then
    DASHBOARD_CACHE_STATUS="ok"
  else
    DASHBOARD_ROWS_CACHE=""
    DASHBOARD_CACHE_STATUS="fetch_error"
  fi
}

render_dashboard() {
  local has_color="$1"
  local refresh="${2:-30}"
  if [[ $has_color -eq 1 ]]; then
    printf '\033[H\033[2J' 2>/dev/null || true
  fi
  render_repl_banner "$has_color"
  echo

  case "${DASHBOARD_CACHE_STATUS:-no_config}" in
    ok)
      render_table "$DASHBOARD_ROWS_CACHE"
      local age=$(( SECONDS - ${DASHBOARD_CACHE_AT:-$SECONDS} ))
      if [[ $has_color -eq 1 && $age -gt 0 ]]; then
        local until=$(( refresh - age ))
        (( until < 0 )) && until=0
        printf '\033[2m  (data %ds old; auto-refresh in %ds, [r] to force)\033[0m\n' "$age" "$until"
      fi
      ;;
    fetch_error)
      # shellcheck disable=SC2016 # backticks intentional in the hint
      printf '\033[33m(could not fetch runner status — check `gh auth status` and try [r])\033[0m\n'
      ;;
    no_config|*)
      local cfg="${CONFIG_FILE:-$(config_path)}"
      cat <<EOF
no fleet configured yet. add one repo per line to:
  $cfg

press [a] to add a repo, or:
  mkdir -p $(dirname "$cfg")
  printf 'acme-corp/api\nacme-corp/web\n' > $cfg
EOF
      ;;
  esac
  echo
  render_repl_footer "$has_color" "$refresh"
}

handle_repl_line() {
  local has_color="$1"; shift
  local line="$*"

  line="${line#"${line%%[![:space:]]*}"}"
  line="${line%"${line##*[![:space:]]}"}"
  [[ -z "$line" ]] && return 0
  history -s -- "$line" 2>/dev/null || true

  case "$line" in
    /help|/?|help|"?")
      repl_help
      ;;
    /quit|/exit|exit|quit)
      DASHBOARD_QUIT=1
      ;;
    /clear|clear)
      # The dashboard loop redraws after every command anyway, so this
      # is effectively a no-op slash that returns to the dashboard.
      :
      ;;
    /repos)
      local f="${CONFIG_FILE:-$(config_path)}"
      if [[ -f "$f" ]]; then
        echo "# $f"; cat "$f"
      else
        echo "(no config file at $f — type \`add OWNER/REPO\` to create it)"
      fi
      ;;
    /*)
      echo "unknown slash command: $line"
      echo "type /help"
      ;;
    *)
      local words=()
      while IFS= read -r w; do
        [[ -n "$w" ]] && words+=("$w")
      done < <(printf '%s' "$line" | xargs -n 1 printf '%s\n' 2>/dev/null || printf '%s' "$line")
      [[ ${#words[@]} -eq 0 ]] && return 0

      local first="${words[0]}"
      case "$first" in
        l|ls) words[0]="list" ;;
        r)    words[0]="restart" ;;
        s)    words[0]="start" ;;
        x)    words[0]="stop" ;;
        n)    words[0]="notify" ;;
        w)    words[0]="watch" ;;
        a)    words[0]="add" ;;
      esac
      case "${words[0]}" in
        list|status|local|start|stop|restart|logs|notify|watch|add|remove|stats|update|doctor|info|setup)
          dispatch_subcommand "${words[@]}" || true
          ;;
        *)
          dispatch_subcommand list "${words[@]}" || true
          ;;
      esac
      ;;
  esac
}

_pause_for_keypress() {
  local has_color="$1"
  if [[ $has_color -eq 1 ]]; then
    printf '\n\033[2m── press any key to return to the dashboard (q to quit) ──\033[0m'
  else
    printf '\n-- press any key to return to the dashboard (q to quit) --'
  fi
  local key
  read -rsn 1 key 2>/dev/null || true
  printf '\n'
  # Treat 'q' as quit-from-anywhere so the user has a consistent way
  # out without bouncing back to the dashboard first.
  if [[ "$key" == "q" || "$key" == "Q" ]]; then
    DASHBOARD_QUIT=1
  fi
}

# Drop into a single-line command prompt below the dashboard. Optional
# second arg is a literal prefix prepended to whatever the user types,
# so the [/] and [a] shortcuts can route into slash/add flows without
# relying on bash 4's `read -e -i` (macOS default is bash 3.2).
prompt_and_run() {
  local has_color="$1"
  local prefix="${2:-}"
  local prompt_marker
  if [[ $has_color -eq 1 ]]; then
    prompt_marker="${THEME_PROMPT}❯${THEME_RESET}"
  else
    prompt_marker='>'
  fi
  echo
  # Show explicit "how to go back" hint so users don't feel trapped in
  # command mode with no obvious exit. Empty Enter or Ctrl-D returns
  # to the dashboard immediately (no "press any key" required).
  if [[ $has_color -eq 1 ]]; then
    printf '\033[2m  (type a command and press Enter, or press Enter alone / Ctrl-D to go back)\033[0m\n'
  else
    printf '  (type a command and press Enter, or press Enter alone / Ctrl-D to go back)\n'
  fi
  if [[ -n "$prefix" ]]; then
    printf '%s %s' "$prompt_marker" "$prefix"
  else
    printf '%s ' "$prompt_marker"
  fi
  local line
  if ! IFS= read -r line; then
    # Ctrl-D / EOF — silent return to dashboard.
    echo
    return 0
  fi
  # Empty Enter (no prefix to combine) — also silent return.
  if [[ -z "$line" && -z "$prefix" ]]; then
    return 0
  fi
  echo
  handle_repl_line "$has_color" "${prefix}${line}"
  _pause_for_keypress "$has_color"
}

# The active monitoring loop: dashboard + key handler. Refreshes every
# REFRESH seconds (default 30). Single-key controls below the dashboard.
dashboard_loop() {
  local refresh="${1:-30}"
  local has_color=0
  [[ -t 1 ]] && has_color=1
  DASHBOARD_QUIT=0
  DASHBOARD_ROWS_CACHE=""
  DASHBOARD_CACHE_AT=0

  # Quit-confirmation state (Claude-Code style): the first Ctrl-D /
  # Esc press arms a quit-pending flag that expires after 3s. A
  # second press within that window actually quits. `q` is explicit
  # and quits on a single press.
  local quit_pending_at=0
  local quit_pending_reason=""

  trap 'echo; DASHBOARD_QUIT=1' INT

  _dashboard_refresh_cache

  while [[ $DASHBOARD_QUIT -eq 0 ]]; do
    # Expire pending quit after 3s.
    if (( quit_pending_at > 0 && SECONDS - quit_pending_at > 3 )); then
      quit_pending_at=0
      quit_pending_reason=""
    fi

    render_dashboard "$has_color" "$refresh"

    # If a quit is pending, surface the confirm hint right above the
    # input line so the user sees how to confirm or back out.
    if [[ -n "$quit_pending_reason" ]]; then
      if [[ $has_color -eq 1 ]]; then
        printf '\033[33m  press %s again to quit (or any other key to cancel)\033[0m\n' "$quit_pending_reason"
      else
        printf '  press %s again to quit (or any other key to cancel)\n' "$quit_pending_reason"
      fi
    fi

    local age=$(( SECONDS - DASHBOARD_CACHE_AT ))
    local remaining=$(( refresh - age ))

    # If we're at or past the refresh interval, refresh immediately
    # without reading. Avoids `read -t 0.01` which works on bash 4+
    # but errors on macOS bash 3.2 ("invalid timeout specification" —
    # that bash only accepts integer timeouts).
    if (( remaining <= 0 )); then
      _dashboard_refresh_cache
      quit_pending_at=0; quit_pending_reason=""
      continue
    fi

    local key="" rc=0
    read -rsn 1 -t "$remaining" key
    rc=$?

    if [[ $rc -eq 1 ]]; then
      # EOF / Ctrl-D
      if [[ "$quit_pending_reason" == "Ctrl-D" ]]; then
        DASHBOARD_QUIT=1
        continue
      fi
      quit_pending_at=$SECONDS
      quit_pending_reason="Ctrl-D"
      continue
    fi

    case "$key" in
      q|Q) DASHBOARD_QUIT=1 ;;
      $'\e')
        # `\e` is both lone Esc AND the first byte of escape sequences.
        # Distinguish by reading follow-up bytes — bash 4+ can use a
        # 50ms fractional timeout, bash 3.2 falls back to a non-blocking
        # peek (arrow-key follow-up bytes are already buffered when
        # we get here, so this works either way).
        local _rest=""
        _read_short_peek _rest || true
        if [[ -n "$_rest" ]]; then
          # Escape sequence — cancel any pending quit and ignore.
          quit_pending_at=0; quit_pending_reason=""
        else
          if [[ "$quit_pending_reason" == "Esc" ]]; then
            DASHBOARD_QUIT=1
          else
            quit_pending_at=$SECONDS
            quit_pending_reason="Esc"
          fi
        fi
        ;;
      r|R)
        _dashboard_refresh_cache
        quit_pending_at=0; quit_pending_reason=""
        ;;
      h|H|"?")
        quit_pending_at=0; quit_pending_reason=""
        repl_help
        _pause_for_keypress "$has_color"
        ;;
      c|C)
        quit_pending_at=0; quit_pending_reason=""
        prompt_and_run "$has_color"
        ;;
      a|A)
        quit_pending_at=0; quit_pending_reason=""
        prompt_and_run "$has_color" "add "
        ;;
      "")
        # Timeout — refresh and clear any pending-quit so the hint
        # doesn't linger across the auto-refresh cycle.
        _dashboard_refresh_cache
        quit_pending_at=0; quit_pending_reason=""
        ;;
      *)
        # Any other key cancels a pending quit and shows the help hint.
        quit_pending_at=0; quit_pending_reason=""
        if [[ $has_color -eq 1 ]]; then
          printf '\r\033[2m  (unknown key — press [h] for help, [q] to quit)\033[0m'
        else
          printf '\r  (unknown key — press [h] for help, [q] to quit)'
        fi
        sleep 1
        ;;
    esac
  done

  trap - INT
  if [[ $has_color -eq 1 ]]; then
    printf '\033[2mbye!\033[0m\n'
  else
    echo "bye!"
  fi
}

interactive_mode() {
  dashboard_loop 30
}

# ---------------------------------------------------------------------------
# Main
# ---------------------------------------------------------------------------

main() {
  require gh
  require jq

  CONFIG_FILE=$(config_path)
  JSON_OUTPUT=0
  local subcommand=""
  local positional=()

  # Parse flags first; allow them anywhere
  local args=()
  while [[ $# -gt 0 ]]; do
    case "$1" in
      -h|--help) usage; exit 0 ;;
      --version) echo "gh-runner-status $VERSION"; exit 0 ;;
      --json) JSON_OUTPUT=1; shift ;;
      --config)
        if [[ $# -lt 2 ]]; then
          echo "error: --config requires a value" >&2
          exit 2
        fi
        CONFIG_FILE="$2"; shift 2 ;;
      --config=*) CONFIG_FILE="${1#--config=}"; shift ;;
      --threshold)
        if [[ $# -lt 2 || ! "$2" =~ ^[0-9]+$ ]]; then
          echo "error: --threshold requires a non-negative integer" >&2
          exit 2
        fi
        NOTIFY_THRESHOLD="$2"; shift 2 ;;
      --threshold=*)
        NOTIFY_THRESHOLD="${1#--threshold=}"
        if [[ ! "$NOTIFY_THRESHOLD" =~ ^[0-9]+$ ]]; then
          echo "error: --threshold requires a non-negative integer" >&2
          exit 2
        fi
        shift ;;
      --) shift; while [[ $# -gt 0 ]]; do args+=("$1"); shift; done ;;
      -*) echo "error: unknown option '$1'" >&2; exit 2 ;;
      *) args+=("$1"); shift ;;
    esac
  done

  # First non-flag arg may be a subcommand. If there's no arg AND stdin
  # is a TTY, drop into the REPL — that's the "just like Claude Code"
  # interactive experience. Non-TTY (cron, pipes) defaults to `list`
  # so existing scripts keep working.
  if [[ ${#args[@]} -eq 0 ]]; then
    if [[ -t 0 && -t 1 ]]; then
      interactive_mode
      exit 0
    fi
    subcommand="list"
  else
    case "${args[0]}" in
      list|status|local|start|stop|restart|logs|notify|watch|add|remove|stats|update|doctor|info|setup)
        subcommand="${args[0]}"
        positional=("${args[@]:1}")
        ;;
      *)
        subcommand="list"
        positional=("${args[@]}")
        ;;
    esac
  fi

  # macOS bash 3.2 errors on `"${empty[@]}"` under set -u; ${var:+...}
  # makes the expansion safe whether positional is empty or populated.
  dispatch_subcommand "$subcommand" ${positional[@]:+"${positional[@]}"}
  local rc=$?
  # Surface validation/usage errors as exit 2 (matches CLI norms);
  # other non-zero returns become exit 1.
  if [[ $rc -ne 0 ]]; then
    exit 2
  fi
  exit 0
}

# Guard so test files can source the script for unit-testing functions
# without triggering the full CLI execution.
if [[ -z "${GH_RUNNER_STATUS_NO_MAIN:-}" ]]; then
  main "$@"
fi
