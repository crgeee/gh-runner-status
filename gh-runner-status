#!/usr/bin/env bash
# gh-runner-status — list, control, and alert on self-hosted GitHub
# Actions runners across one or more repositories.
#
# Subcommands:
#   list / status (default)  show runner status table across repos
#   local                    list runners installed on this machine
#   start <NAME>             start a local runner
#   stop <NAME>              stop a local runner
#   restart <NAME>           restart a local runner
#   logs <NAME>              tail recent logs from a local runner
#   notify                   send a Telegram alert if any runner is offline
#
# Run `gh runner-status --help` for full usage.

set -euo pipefail

VERSION="0.2.0"

tmpdir=""
trap 'rm -rf "${tmpdir:-}"' EXIT

# ---------------------------------------------------------------------------
# Helpers
# ---------------------------------------------------------------------------

usage() {
  cat <<'EOF'
gh-runner-status — list, control, and alert on self-hosted Actions runners

USAGE:
  gh runner-status [SUBCOMMAND] [ARGS...] [OPTIONS]

SUBCOMMANDS:
  list, status (default)
      Show runner status table across all configured repos. With repos
      passed as args, only those are queried.

  local
      List self-hosted runners installed on the local machine
      (LaunchAgents on macOS, systemd user services on Linux).

  start NAME      Start a local runner by service name.
  stop NAME       Stop a local runner.
  restart NAME    Restart a local runner.
  logs NAME       Tail the most recent stdout/stderr logs.

  watch [SECONDS]
      Auto-refresh the status table on an interval (default 30s).
      Ctrl-C to exit.

  notify
      Query all configured repos and send a Telegram alert if any
      runner is offline or errored. Designed for cron / launchd.

  (no args, in a TTY)
      Drops into an interactive REPL with slash commands and
      short-form aliases. See in-REPL `/help` for details.

OPTIONS:
  --config FILE   Read repos from FILE (one per line). Default:
                  $XDG_CONFIG_HOME/gh-runner-status/repos
                  or ~/.config/gh-runner-status/repos
  --json          Print raw JSON instead of the table (list/local/notify)
  --threshold N   For `notify`: only alert if N+ runners are offline
                  (default 1)
  -h, --help      Show this message
  --version       Show version

EXAMPLES:
  gh runner-status
  gh runner-status owner/repo-a
  gh runner-status owner/repo-a,owner/repo-b
  gh runner-status --json | jq '.[] | select(.status == "offline")'
  gh runner-status local
  gh runner-status restart actions.runner.owner-repo.runner-1
  gh runner-status notify

CONFIG FILE FORMAT:
  Lines beginning with '#' are comments. One "owner/repo" per line.

      owner/repo-a
      owner/repo-b

TELEGRAM (optional, used by `notify`):
  Set in env or in $XDG_CONFIG_HOME/gh-runner-status/telegram:

      TELEGRAM_BOT_TOKEN=123456:ABC...
      TELEGRAM_CHAT_ID=-1001234567890

  Get a bot token from @BotFather; chat ID from @userinfobot.
EOF
}

require() {
  command -v "$1" >/dev/null 2>&1 || {
    echo "error: '$1' is required but not installed" >&2
    exit 2
  }
}

# Reject anything that doesn't look like "owner/repo" — keeps us from
# building URLs like `repos/../../user/...` or accepting `?` / `#` in
# the path. GitHub itself only allows [A-Za-z0-9._-] in owner and repo
# names, so this is the canonical shape.
validate_repo() {
  local repo="$1"
  if [[ ! "$repo" =~ ^[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+$ ]]; then
    echo "error: invalid repo (expected owner/name, got: $repo)" >&2
    return 1
  fi
}

# Block runner names that could be reparsed as flags by launchctl/
# systemctl/tail (e.g. "--no-block", "default.target"). The GitHub
# installer always names runners actions.runner.<owner>-<repo>.<runner>.
validate_runner_name() {
  local name="$1"
  # Match `actions.runner.<owner>-<repo>.<runner>` exactly. Two segments
  # after the prefix, neither may start with `-` (which would make the
  # name reparse as a flag by launchctl/systemctl/tail).
  if [[ ! "$name" =~ ^actions\.runner\.[A-Za-z0-9_][A-Za-z0-9_.-]*\.[A-Za-z0-9_][A-Za-z0-9_.-]*$ ]]; then
    echo "error: invalid runner name (expected actions.runner.OWNER-REPO.NAME, got: $name)" >&2
    return 1
  fi
}

config_dir() {
  echo "${XDG_CONFIG_HOME:-$HOME/.config}/gh-runner-status"
}

config_path() {
  echo "$(config_dir)/repos"
}

read_config() {
  local file="$1"
  if [[ ! -f "$file" ]]; then
    echo "error: config file not found: $file" >&2
    echo "create it with one 'owner/repo' per line, or pass repos as arguments" >&2
    exit 1
  fi
  # strip comments (# to end-of-line) and blank lines
  sed 's/#.*//' "$file" | awk 'NF > 0 { print $1 }'
}

# Source $XDG_CONFIG_HOME/gh-runner-status/telegram if it exists,
# unless the env vars are already set.
load_telegram_config() {
  local cfg
  cfg="$(config_dir)/telegram"
  if [[ -z "${TELEGRAM_BOT_TOKEN:-}" || -z "${TELEGRAM_CHAT_ID:-}" ]]; then
    if [[ -f "$cfg" ]]; then
      # Read KEY=VALUE pairs without sourcing arbitrary shell — `source`
      # would let a malicious config run code (mkdir, curl, anything).
      # Only accept TELEGRAM_BOT_TOKEN and TELEGRAM_CHAT_ID, exact form.
      while IFS='=' read -r key value; do
        # Strip surrounding quotes and whitespace
        key="${key#"${key%%[![:space:]]*}"}"
        key="${key%"${key##*[![:space:]]}"}"
        value="${value#"${value%%[![:space:]]*}"}"
        value="${value%"${value##*[![:space:]]}"}"
        value="${value#\"}"; value="${value%\"}"
        value="${value#\'}"; value="${value%\'}"
        value="${value%$'\r'}"  # tolerate Windows-edited config
        case "$key" in
          TELEGRAM_BOT_TOKEN)
            [[ -z "${TELEGRAM_BOT_TOKEN:-}" ]] && export TELEGRAM_BOT_TOKEN="$value"
            ;;
          TELEGRAM_CHAT_ID)
            [[ -z "${TELEGRAM_CHAT_ID:-}" ]] && export TELEGRAM_CHAT_ID="$value"
            ;;
          ""|\#*) ;; # skip comments / blanks
        esac
      done < <(grep -E '^(TELEGRAM_(BOT_TOKEN|CHAT_ID)|#)' "$cfg" 2>/dev/null || true)
    fi
  fi
}

# ---------------------------------------------------------------------------
# Remote: fetch runners via gh API
# ---------------------------------------------------------------------------

fetch_runners() {
  # Repo is validated upstream; this function may run in a backgrounded
  # subshell where `exit` wouldn't propagate, so we don't re-validate here.
  local repo="$1"
  local response
  if ! response=$(gh api "repos/${repo}/actions/runners" --paginate 2>&1); then
    # Surface the error inline so the user sees it; do not crash the
    # whole run on one bad repo.
    jq -nc --arg repo "$repo" --arg err "$response" \
      '{repo: $repo, error: $err}'
    return
  fi
  jq -c --arg repo "$repo" \
    'if .runners then .runners[] | {repo: $repo, name, status, busy, os, labels: [.labels[].name]}
     else {repo: $repo, error: "unexpected API response"} end' \
    <<<"$response"
}

collect_remote_runners() {
  # Args: list of repos. Outputs newline-delimited JSON to stdout.
  local repos=("$@")
  # Validate every repo upfront so a bad name fails fast before we
  # spawn parallel API calls.
  for repo in "${repos[@]}"; do
    validate_repo "$repo" || return 1
  done
  tmpdir=$(mktemp -d)
  local i=0
  for repo in "${repos[@]}"; do
    fetch_runners "$repo" >"$tmpdir/$i" &
    i=$((i + 1))
  done
  wait
  for f in "$tmpdir"/*; do
    [[ -s "$f" ]] || continue
    cat "$f"
    echo  # ensure trailing newline between files
  done
}

render_table() {
  local rows="$1"
  if [[ -z "$rows" ]]; then
    echo "(no runners found)"
    return
  fi

  # Single jq pass projects each row into TAB-delimited columns; awk
  # handles column-width measurement and ANSI coloring in one stream.
  # Avoids spawning ~5 jq processes per runner (was 500+ for 100 runners).
  local color_enabled=0
  [[ -t 1 ]] && color_enabled=1

  # Status icons add a glanceable signal column that pairs with the
  # text status. Disabled with NO_ICONS=1 for environments that don't
  # render unicode reliably (some CI log viewers, ASCII-only terminals).
  local icons_enabled=1
  [[ "${NO_ICONS:-0}" == "1" ]] && icons_enabled=0

  jq -rs '.[] |
    [
      (.repo // "?"),
      (.name // .error // "?"),
      (.status // "error"),
      (if .busy == true then "yes" elif .busy == false then "no" else "-" end),
      (if .labels then (.labels | join(",")) else "-" end)
    ] | @tsv' <<<"$rows" \
  | awk -F'\t' -v color="$color_enabled" -v icons="$icons_enabled" '
    BEGIN { wi=2; wr=4; wn=4; ws=6; wb=4 }
    {
      lines[NR] = $0
      if (length($1) > wr) wr = length($1)
      if (length($2) > wn) wn = length($2)
      if (length($3) > ws) ws = length($3)
      if (length($4) > wb) wb = length($4)
    }
    function icon_for(status) {
      if (!icons) return ""
      if (status == "online")  return "✓"
      if (status == "offline") return "✗"
      if (status == "error")   return "⚠"
      return "•"
    }
    END {
      hdr_icon = icons ? "  " : ""
      printf "%s%-*s  %-*s  %-*s  %-*s  %s\n", hdr_icon, wr, "REPO", wn, "NAME", ws, "STATUS", wb, "BUSY", "LABELS"
      total = (icons ? 4 : 0) + wr + wn + ws + wb + 20
      for (i = 0; i < total; i++) printf "-"
      printf "\n"
      for (i = 1; i <= NR; i++) {
        split(lines[i], f, "\t")
        c = ""; r = ""
        if (color) {
          r = "\033[0m"
          if (f[3] == "online")  c = "\033[32m"
          else if (f[3] == "offline") c = "\033[31m"
          else if (f[3] == "error")   c = "\033[33m"
        }
        ic = icon_for(f[3])
        if (icons) printf "%s%s ", c, ic
        printf "%s%-*s%s  %-*s  %s%-*s%s  %-*s  %s\n", \
          (icons ? r : ""), wr, f[1], "", wn, f[2], c, ws, f[3], r, wb, f[4], f[5]
      }
    }'
}

# ---------------------------------------------------------------------------
# Local: discover and control runners installed on this machine
# ---------------------------------------------------------------------------

detect_os() {
  case "$(uname -s)" in
    Darwin) echo "macos" ;;
    Linux)  echo "linux" ;;
    *)      echo "unsupported" ;;
  esac
}

# ---------------------------------------------------------------------------
# Host / runner metrics — used by the dashboard and `local` table
# ---------------------------------------------------------------------------

# Pretty host uptime ("5d 2h", "1h 14m", "23m"). Cross-platform via
# `uptime` parsing — both macOS and Linux print "up X..." in the prefix.
host_uptime_pretty() {
  uptime 2>/dev/null \
    | sed -E 's/^[^,]*up *([^,]+).*$/\1/' \
    | sed -E 's/^[[:space:]]+|[[:space:]]+$//g' \
    | sed -E 's/ days?,? */d /;s/ hrs?,? */h /;s/ mins?,? */m /' \
    | sed -E 's/:([0-9]+) *$/h \1m/' \
    | sed -E 's/[[:space:]]+/ /g'
}

host_load_avg() {
  uptime 2>/dev/null \
    | sed -E 's/.*load averages?: *//' \
    | sed -E 's/,/ /g' \
    | awk '{print $1, $2, $3}'
}

# Used / total memory, like "8.2/16G". macOS uses sysctl + vm_stat;
# Linux reads /proc/meminfo. Returns "?/?" if neither path works.
host_mem_pretty() {
  local os used_bytes total_bytes
  os=$(detect_os)
  case "$os" in
    macos)
      total_bytes=$(sysctl -n hw.memsize 2>/dev/null || echo 0)
      local pagesize active wired
      pagesize=$(vm_stat 2>/dev/null | head -1 | awk -F'of ' '{print $2}' | tr -dc '0-9')
      active=$(vm_stat 2>/dev/null | awk '/Pages active/ {gsub(/\./,""); print $3}')
      wired=$(vm_stat 2>/dev/null | awk '/Pages wired down/ {gsub(/\./,""); print $4}')
      if [[ -n "$pagesize" && -n "$active" && -n "$wired" ]]; then
        used_bytes=$(( (active + wired) * pagesize ))
      else
        used_bytes=0
      fi
      ;;
    linux)
      if [[ -r /proc/meminfo ]]; then
        local total_kb avail_kb
        total_kb=$(awk '/^MemTotal:/ {print $2}' /proc/meminfo)
        avail_kb=$(awk '/^MemAvailable:/ {print $2}' /proc/meminfo)
        total_bytes=$(( total_kb * 1024 ))
        used_bytes=$(( (total_kb - avail_kb) * 1024 ))
      else
        echo "?/?"
        return 0
      fi
      ;;
    *)
      echo "?/?"
      return 0
      ;;
  esac

  if [[ "$total_bytes" -le 0 ]]; then
    echo "?/?"
    return 0
  fi

  awk -v u="$used_bytes" -v t="$total_bytes" 'BEGIN {
    gb = 1073741824
    printf "%.1f/%.1fG", u/gb, t/gb
  }'
}

# Single-line summary for the dashboard banner: "uptime: 5d 2h • load: 1.2 1.4 1.5 • mem: 8.2/16G"
host_summary() {
  local up load mem
  up=$(host_uptime_pretty 2>/dev/null || echo "?")
  load=$(host_load_avg 2>/dev/null || echo "? ? ?")
  mem=$(host_mem_pretty 2>/dev/null || echo "?/?")
  printf 'uptime: %s • load: %s • mem: %s' "$up" "$load" "$mem"
}

# Resolve the PID of a running runner service. Empty string if not running.
local_runner_pid() {
  validate_runner_name "$1" >/dev/null 2>&1 || { echo ""; return 0; }
  local name="$1"
  local os
  os=$(detect_os)
  case "$os" in
    macos)
      # Plain `launchctl list` (no arg) prints "PID\tEXIT\tLABEL" rows;
      # column 1 is the PID, "-" when the agent is not running.
      local pid
      pid=$(launchctl list 2>/dev/null | awk -v n="$name" '$NF==n && $1 != "-" {print $1}')
      echo "${pid:-}"
      ;;
    linux)
      local pid
      pid=$(systemctl --user show -P MainPID "$name" 2>/dev/null)
      [[ -z "$pid" || "$pid" == "0" ]] && pid=$(systemctl show -P MainPID "$name" 2>/dev/null)
      [[ "$pid" == "0" ]] && pid=""
      echo "${pid:-}"
      ;;
    *)
      echo ""
      ;;
  esac
}

# Given a PID, return "etime|cpu|rss_kb" via ps. Empty fields on failure.
local_runner_metrics_for_pid() {
  local pid="$1"
  [[ -z "$pid" ]] && { echo "||"; return 0; }
  ps -o etime=,pcpu=,rss= -p "$pid" 2>/dev/null \
    | awk '{
        gsub(/^[[:space:]]+|[[:space:]]+$/, "", $0);
        printf "%s|%s|%s", $1, $2, $3
      }' || echo "||"
}

# Format kilobyte count as "45M" or "1.2G" for compact display.
fmt_rss() {
  local kb="$1"
  [[ -z "$kb" || "$kb" == "0" ]] && { echo "-"; return 0; }
  awk -v k="$kb" 'BEGIN {
    if (k >= 1048576)      printf "%.1fG", k/1048576
    else if (k >= 1024)    printf "%dM", k/1024
    else                   printf "%dK", k
  }'
}

# Format ps etime ("DD-HH:MM:SS" or "HH:MM:SS" or "MM:SS") into "5d 2h" style.
fmt_etime() {
  local e="$1"
  [[ -z "$e" ]] && { echo "-"; return 0; }
  awk -v t="$e" 'BEGIN {
    n = split(t, a, "-")
    days = 0; rest = t
    if (n == 2) { days = a[1]; rest = a[2] }
    n2 = split(rest, b, ":")
    if (n2 == 3) { h = b[1]; m = b[2] }
    else if (n2 == 2) { h = 0; m = b[1] }
    else { h = 0; m = 0 }
    if (days > 0) printf "%dd %dh", days, h
    else if (h > 0) printf "%dh %dm", h, m
    else printf "%dm", m
  }'
}

list_local_runners() {
  local os
  os=$(detect_os)
  case "$os" in
    macos)
      # GitHub's installer drops a plist named `actions.runner.<owner>-<repo>.<runner>.plist`
      local agents_dir="$HOME/Library/LaunchAgents"
      [[ -d "$agents_dir" ]] || return 0
      find "$agents_dir" -maxdepth 1 -name 'actions.runner.*.plist' -print 2>/dev/null \
        | sed 's|.*/||;s|\.plist$||'
      ;;
    linux)
      # systemctl pattern; user services first, then system. Dedupe
      # output so a runner registered in both managers doesn't appear
      # twice. `|| true` swallows missing-D-Bus-session failures
      # (common under cron without lingering enabled).
      {
        systemctl --user list-units --type=service --all --no-legend 'actions.runner.*' 2>/dev/null || true
        systemctl list-units --type=service --all --no-legend 'actions.runner.*' 2>/dev/null || true
      } | awk '{print $1}' | sed 's|\.service$||' | awk 'NF' | sort -u
      ;;
    *)
      echo "error: local runner control not supported on this OS" >&2
      return 1
      ;;
  esac
}

local_runner_action() {
  local action="$1" name="$2"
  validate_runner_name "$name"
  local os
  os=$(detect_os)
  case "$os" in
    macos)
      local agents_dir="$HOME/Library/LaunchAgents"
      local plist="$agents_dir/${name}.plist"
      if [[ ! -f "$plist" ]]; then
        echo "error: no LaunchAgent at $plist" >&2
        echo "Run \`gh runner-status local\` to see installed runners." >&2
        return 1
      fi
      local uid target
      uid=$(id -u)
      target="gui/${uid}/${name}"
      case "$action" in
        start)
          launchctl bootstrap "gui/$(id -u)" "$plist" 2>&1 \
            | grep -v "service already loaded" || true
          echo "started: $name"
          ;;
        stop)
          launchctl bootout "$target" 2>&1 \
            | grep -v "Could not find specified service" || true
          echo "stopped: $name"
          ;;
        restart)
          launchctl bootout "$target" 2>/dev/null || true
          launchctl bootstrap "gui/$(id -u)" "$plist"
          echo "restarted: $name"
          ;;
      esac
      ;;
    linux)
      case "$action" in
        start)   systemctl --user start "$name" 2>/dev/null || sudo systemctl start "$name" ;;
        stop)    systemctl --user stop "$name" 2>/dev/null || sudo systemctl stop "$name" ;;
        restart) systemctl --user restart "$name" 2>/dev/null || sudo systemctl restart "$name" ;;
      esac
      echo "${action}ed: $name"
      ;;
    *)
      echo "error: local runner control not supported on this OS" >&2
      return 1
      ;;
  esac
}

local_runner_logs() {
  local name="$1"
  validate_runner_name "$name"
  local os
  os=$(detect_os)
  case "$os" in
    macos)
      local logs_dir="$HOME/Library/Logs/${name}"
      if [[ ! -d "$logs_dir" ]]; then
        echo "error: no logs at $logs_dir" >&2
        return 1
      fi
      # Show last 50 lines from each log file
      for f in "$logs_dir"/*.log; do
        [[ -f "$f" ]] || continue
        echo "── $f ──"
        tail -n 50 "$f"
        echo
      done
      ;;
    linux)
      journalctl --user -u "$name" -n 100 --no-pager 2>/dev/null \
        || journalctl -u "$name" -n 100 --no-pager
      ;;
    *)
      echo "error: log retrieval not supported on this OS" >&2
      return 1
      ;;
  esac
}

# ---------------------------------------------------------------------------
# Notify: send Telegram alert on offline/errored runners
# ---------------------------------------------------------------------------

telegram_send() {
  local message="$1"
  # Strip CR (Windows-edited config) which would corrupt the URL.
  local token="${TELEGRAM_BOT_TOKEN%$'\r'}"
  local chat="${TELEGRAM_CHAT_ID%$'\r'}"
  if [[ -z "$token" || -z "$chat" ]]; then
    echo "error: TELEGRAM_BOT_TOKEN and TELEGRAM_CHAT_ID required" >&2
    echo "set them in env or $(config_dir)/telegram" >&2
    return 1
  fi

  # Write the message to a temp file and pass via `data-urlencode = "text@FILE"`.
  # curl reads the file's contents and url-encodes them — handles arbitrary
  # newlines, quotes, and backslashes that would otherwise break the
  # line-oriented config syntax. Token still lands via stdin (--config -),
  # not argv, so `ps auxe` can't see it.
  local msg_file
  msg_file=$(mktemp)
  # Trap-local cleanup; don't disturb the script-level EXIT trap that
  # cleans up tmpdir.
  printf '%s' "$message" >"$msg_file"

  local http
  http=$(curl -sS -X POST --config - -o /dev/null -w '%{http_code}' <<EOF
url = "https://api.telegram.org/bot${token}/sendMessage"
data-urlencode = "chat_id=${chat}"
data-urlencode = "text@${msg_file}"
data-urlencode = "disable_notification=false"
EOF
)
  rm -f "$msg_file"
  [[ "$http" == "200" ]]
}

run_notify() {
  local repos=("$@")
  local rows
  rows=$(collect_remote_runners "${repos[@]}")
  local threshold="${NOTIFY_THRESHOLD:-1}"

  # Count separately so "all repos errored" doesn't masquerade as healthy.
  local counts
  counts=$(jq -rs '
    {
      total:    length,
      offline: ([.[] | select(.status == "offline")] | length),
      err:     ([.[] | select(has("error"))] | length)
    } | "\(.total) \(.offline) \(.err)"
  ' <<<"$rows" 2>/dev/null || echo "0 0 0")
  local total offline_count error_count
  read -r total offline_count error_count <<<"$counts"
  local bad_count=$(( offline_count + error_count ))

  # Edge case: every repo errored (bad token / network down). Always
  # alert regardless of threshold — silent failure is the worst outcome.
  # fetch_runners emits one {repo, error} object per failed repo, so
  # error_count == #repos AND offline_count == 0 means total failure.
  local total_repo_failure=0
  if [[ $error_count -ge ${#repos[@]} && $offline_count -eq 0 ]]; then
    total_repo_failure=1
  fi

  if [[ $total_repo_failure -eq 0 && $bad_count -lt $threshold ]]; then
    local online_count=$(( total - offline_count - error_count ))
    echo "ok: $online_count runner(s) online across ${#repos[@]} repo(s)"
    return 0
  fi

  local detail
  detail=$(jq -rs '
    [.[] | select(.status == "offline" or has("error"))]
    | map("• \(.repo) / \(.name // "?") — \(.error // .status)")
    | .[]
  ' <<<"$rows")

  local short_host
  short_host=${HOSTNAME%%.*}
  [[ -z "$short_host" ]] && short_host=$(hostname 2>/dev/null || echo "unknown")

  local headline
  if [[ $total_repo_failure -eq 1 ]]; then
    headline="🚨 gh-runner-status: ALL repo lookups failed"
  else
    headline="🚨 gh-runner-status: ${bad_count} runner(s) need attention"
  fi

  local online_count=$(( total - offline_count - error_count ))
  local message
  message="${headline}
Host: ${short_host}
Online: ${online_count}/${total}; Offline: ${offline_count}; Errored: ${error_count}

${detail}"

  echo "$message"
  echo "---"
  if telegram_send "$message"; then
    echo "alert sent to Telegram"
  else
    echo "error: telegram_send failed (HTTP non-200)" >&2
    return 1
  fi
}

# ---------------------------------------------------------------------------
# Subcommand dispatch — shared between one-shot CLI and interactive REPL
# ---------------------------------------------------------------------------

# Args: <subcommand> [positional...]. Reads CONFIG_FILE, JSON_OUTPUT,
# NOTIFY_THRESHOLD from the environment. Returns 0 on success, 1 on
# user error, 2 on bad args. Never calls exit; the REPL needs to
# survive errors.
dispatch_subcommand() {
  local subcommand="$1"; shift
  local positional=("$@")

  case "$subcommand" in
    list|status)
      local repos=()
      if [[ ${#positional[@]} -gt 0 ]]; then
        for arg in "${positional[@]}"; do
          while IFS= read -r r; do
            [[ -n "$r" ]] && repos+=("$r")
          done < <(tr ',' '\n' <<<"$arg")
        done
      else
        while IFS= read -r r; do
          [[ -n "$r" ]] && repos+=("$r")
        done < <(read_config "${CONFIG_FILE:-$(config_path)}" 2>&1) || return 1
      fi

      if [[ ${#repos[@]} -eq 0 ]]; then
        echo "error: no repos (pass as args or populate ${CONFIG_FILE:-$(config_path)})" >&2
        return 1
      fi

      local rows
      rows=$(collect_remote_runners "${repos[@]}") || return 1

      if [[ "${JSON_OUTPUT:-0}" -eq 1 ]]; then
        if [[ -z "$rows" ]]; then echo "[]"; else jq -s '.' <<<"$rows"; fi
      else
        render_table "$rows"
      fi
      ;;

    local)
      if [[ "${JSON_OUTPUT:-0}" -eq 1 ]]; then
        # JSON: include metrics too for scripting/automation
        local first=1
        echo "["
        while IFS= read -r r; do
          [[ -z "$r" ]] && continue
          local pid metrics etime cpu rss
          pid=$(local_runner_pid "$r")
          metrics=$(local_runner_metrics_for_pid "$pid")
          IFS='|' read -r etime cpu rss <<<"$metrics"
          [[ $first -eq 0 ]] && echo ","
          first=0
          jq -nc --arg name "$r" --arg pid "${pid:-}" --arg etime "${etime:-}" \
                 --arg cpu "${cpu:-}" --arg rss_kb "${rss:-}" \
            '{name: $name, pid: ($pid | select(. != "")), running: ($pid != ""),
              etime: ($etime | select(. != "")), cpu_pct: ($cpu | select(. != "") | tonumber? // null),
              rss_kb: ($rss_kb | select(. != "") | tonumber? // null)}'
        done < <(list_local_runners)
        echo "]"
      else
        local rows=()
        while IFS= read -r r; do
          [[ -z "$r" ]] && continue
          local pid metrics etime cpu rss state etime_pretty rss_pretty cpu_pretty
          pid=$(local_runner_pid "$r")
          if [[ -n "$pid" ]]; then
            state="running"
            metrics=$(local_runner_metrics_for_pid "$pid")
            IFS='|' read -r etime cpu rss <<<"$metrics"
            etime_pretty=$(fmt_etime "${etime:-}")
            rss_pretty=$(fmt_rss "${rss:-}")
            cpu_pretty="${cpu:--}%"
          else
            state="stopped"; pid="-"; etime_pretty="-"; rss_pretty="-"; cpu_pretty="-"
          fi
          rows+=("$state|$r|${pid}|$etime_pretty|$cpu_pretty|$rss_pretty")
        done < <(list_local_runners)

        if [[ ${#rows[@]} -eq 0 ]]; then
          echo "(no local runners found)"
          return 0
        fi

        local color_enabled=0
        [[ -t 1 ]] && color_enabled=1
        printf '%s\n' "${rows[@]}" | awk -F'|' -v color="$color_enabled" '
          BEGIN { wn=4; wp=3; wu=6; wc=4; wm=4 }
          { lines[NR]=$0
            if (length($2) > wn) wn = length($2)
            if (length($3) > wp) wp = length($3)
            if (length($4) > wu) wu = length($4)
            if (length($5) > wc) wc = length($5)
            if (length($6) > wm) wm = length($6) }
          END {
            printf "  %-*s  %-*s  %-*s  %-*s  %-*s\n", wn, "NAME", wp, "PID", wu, "UPTIME", wc, "CPU", wm, "MEM"
            tot = 4 + wn + wp + wu + wc + wm + 8
            for (i=0;i<tot;i++) printf "-"
            printf "\n"
            for (i=1; i<=NR; i++) {
              split(lines[i], f, "|")
              icon = (f[1]=="running") ? "✓" : "✗"
              c = ""; r = ""
              if (color) { r = "\033[0m"; c = (f[1]=="running") ? "\033[32m" : "\033[31m" }
              printf "%s%s%s %-*s  %-*s  %-*s  %-*s  %-*s\n", \
                c, icon, r, wn, f[2], wp, f[3], wu, f[4], wc, f[5], wm, f[6]
            }
          }'
      fi
      ;;

    start|stop|restart)
      if [[ ${#positional[@]} -ne 1 ]]; then
        echo "error: $subcommand requires exactly one runner name" >&2
        echo "use \`local\` to list installed runners" >&2
        return 2
      fi
      local_runner_action "$subcommand" "${positional[0]}"
      ;;

    logs)
      if [[ ${#positional[@]} -ne 1 ]]; then
        echo "error: logs requires exactly one runner name" >&2
        return 2
      fi
      local_runner_logs "${positional[0]}"
      ;;

    add)
      # `add OWNER/REPO [NAME] [LABELS]` — generates a registration token,
      # appends the repo to the config file, prints the exact commands to
      # paste on the target machine. Doesn't auto-install (downloading +
      # extracting + configuring + service install is platform-specific
      # and would require sudo on Linux).
      if [[ ${#positional[@]} -lt 1 ]]; then
        echo "error: add requires owner/repo" >&2
        echo "usage: add OWNER/REPO [RUNNER_NAME] [LABELS]" >&2
        return 2
      fi
      local repo="${positional[0]}"
      validate_repo "$repo" || return 2
      local runner_name="${positional[1]:-$(hostname -s 2>/dev/null || echo runner-$RANDOM)}"
      local labels="${positional[2]:-self-hosted}"

      local token_resp
      if ! token_resp=$(gh api "repos/${repo}/actions/runners/registration-token" -X POST 2>&1); then
        echo "error: could not get registration token: $token_resp" >&2
        return 1
      fi
      local token
      token=$(jq -r '.token' <<<"$token_resp")
      if [[ -z "$token" || "$token" == "null" ]]; then
        echo "error: registration-token API returned no token" >&2
        return 1
      fi

      local cfg_file="${CONFIG_FILE:-$(config_path)}"
      mkdir -p "$(dirname "$cfg_file")"
      if [[ -f "$cfg_file" ]] && grep -qxF "$repo" "$cfg_file" 2>/dev/null; then
        : # already in config
      else
        echo "$repo" >> "$cfg_file"
        echo "added $repo to $cfg_file"
      fi

      cat <<EOF

Registration token (valid ~1 hour):
  $token

To install on the target machine, run these commands there:

  # 1. Download + extract latest runner
  mkdir actions-runner && cd actions-runner
  RUNNER_VERSION=\$(curl -s https://api.github.com/repos/actions/runner/releases/latest | jq -r .tag_name | sed 's/^v//')
  OS_LABEL=\$(uname -s | tr '[:upper:]' '[:lower:]'); [[ "\$OS_LABEL" == "darwin" ]] && OS_LABEL="osx"
  ARCH=\$(uname -m); [[ "\$ARCH" == "arm64" || "\$ARCH" == "aarch64" ]] && ARCH="arm64" || ARCH="x64"
  curl -sL "https://github.com/actions/runner/releases/download/v\${RUNNER_VERSION}/actions-runner-\${OS_LABEL}-\${ARCH}-\${RUNNER_VERSION}.tar.gz" | tar xz

  # 2. Register against the repo
  ./config.sh \\
      --url https://github.com/${repo} \\
      --token ${token} \\
      --name ${runner_name} \\
      --labels ${labels} \\
      --work _work \\
      --unattended --replace

  # 3. Install + start as a service (macOS LaunchAgent / Linux systemd)
  ./svc.sh install
  ./svc.sh start

After it's running, this CLI will pick it up automatically: \`gh runner-status\` should show it as 'online'.
EOF
      ;;

    remove)
      # `remove OWNER/REPO RUNNER_NAME_OR_ID` — deregisters a runner from
      # GitHub via the API. Does NOT touch local files; the user can run
      # \`gh runner-status stop\` then delete the runner directory if they
      # also want to clean up local install artifacts.
      if [[ ${#positional[@]} -lt 2 ]]; then
        echo "error: remove requires owner/repo and runner-name-or-id" >&2
        echo "usage: remove OWNER/REPO RUNNER_NAME_OR_ID" >&2
        return 2
      fi
      local repo="${positional[0]}"
      local target="${positional[1]}"
      validate_repo "$repo" || return 2

      # Resolve name → id (and id → name when caller gave an id, so the
      # cleanup hint can build a correct LaunchAgent label).
      local runner_id runner_name
      local runners_json
      runners_json=$(gh api "repos/${repo}/actions/runners" --paginate 2>/dev/null || echo '{"runners":[]}')
      if [[ "$target" =~ ^[0-9]+$ ]]; then
        runner_id="$target"
        runner_name=$(jq -r --argjson id "$target" '.runners[] | select(.id == $id) | .name' <<<"$runners_json" | head -1)
      else
        runner_id=$(jq -r --arg n "$target" '.runners[] | select(.name == $n) | .id' <<<"$runners_json" | head -1)
        runner_name="$target"
        if [[ -z "$runner_id" ]]; then
          echo "error: no runner named '$target' in $repo" >&2
          echo "tip: list runners with \`gh runner-status $repo\`" >&2
          return 1
        fi
      fi

      if ! gh api "repos/${repo}/actions/runners/${runner_id}" -X DELETE >/dev/null 2>&1; then
        echo "error: failed to deregister runner $runner_id from $repo" >&2
        return 1
      fi
      echo "deregistered runner ${runner_name:-$target} ($runner_id) from $repo"
      echo "note: local files (LaunchAgent, runner directory) are untouched."
      echo "      to fully uninstall locally:"
      if [[ -n "$runner_name" ]]; then
        echo "        gh runner-status stop actions.runner.${repo//\//-}.${runner_name}"
      else
        echo "        gh runner-status stop actions.runner.${repo//\//-}.<runner-name>"
      fi
      echo "        rm -rf <runner_install_dir>"
      ;;

    watch)
      # `watch [SECONDS] [REPOS...]` — same active dashboard as bare
      # `gh runner-status`, with a custom refresh interval and an
      # optional repo subset. Single-key controls (q/r/c/a/h) work in
      # both TTY and the non-TTY fallback (no key handling there).
      local interval="${WATCH_INTERVAL:-30}"
      if [[ "${positional[0]:-}" =~ ^[0-9]+$ ]]; then
        interval="${positional[0]}"
        positional=("${positional[@]:1}")
      fi
      if [[ ! -t 0 || ! -t 1 ]]; then
        # Non-TTY (cron, piped): print-and-sleep loop. Repo args
        # forward to `list` if given.
        while true; do
          dispatch_subcommand list ${positional[@]:+"${positional[@]}"} || true
          sleep "$interval"
          echo
        done
      else
        # TTY: enter the dashboard loop. The dashboard always reads
        # repos from CONFIG_FILE (passing repos to `list` via the
        # dashboard isn't wired through render_dashboard yet — would
        # require threading the args through; left as a follow-up).
        # If the caller passed explicit repos, hint that they're
        # currently filtered out.
        if [[ ${#positional[@]} -gt 0 ]]; then
          # shellcheck disable=SC2016 # backticks are intentional literal text in the user-facing hint
          printf '\033[33m(note: `watch SECONDS REPOS...` repo filter not yet supported in TTY dashboard;\n showing all configured repos. Use `gh runner-status owner/repo` for one-off filtering.)\033[0m\n' >&2
          sleep 2
        fi
        dashboard_loop "$interval"
      fi
      ;;

    notify)
      load_telegram_config
      command -v curl >/dev/null 2>&1 || {
        echo "error: 'curl' is required for notify" >&2
        return 2
      }
      local repos=()
      if [[ ${#positional[@]} -gt 0 ]]; then
        for arg in "${positional[@]}"; do
          while IFS= read -r r; do
            [[ -n "$r" ]] && repos+=("$r")
          done < <(tr ',' '\n' <<<"$arg")
        done
      else
        while IFS= read -r r; do
          [[ -n "$r" ]] && repos+=("$r")
        done < <(read_config "${CONFIG_FILE:-$(config_path)}" 2>&1) || return 1
      fi

      if [[ ${#repos[@]} -eq 0 ]]; then
        echo "error: no repos given for notify" >&2
        return 1
      fi

      run_notify "${repos[@]}"
      ;;

    *)
      echo "error: unknown command '$subcommand'" >&2
      echo "type /help for available commands" >&2
      return 2
      ;;
  esac
}

# ---------------------------------------------------------------------------
# Interactive mode (REPL)
# ---------------------------------------------------------------------------

repl_help() {
  cat <<'EOF'
Dashboard keys (single keystroke, no Enter):
  r           Refresh now
  c           Command mode (one full command, then back to dashboard)
  /           Slash command
  a           Add a repo (shortcut to command-mode `add OWNER/REPO`)
  h, ?        This help
  q, Ctrl-D   Quit

Slash commands:
  /help, /?      Show this help
  /repos         Show configured repos
  /clear         Re-render dashboard with fresh state
  /quit, /exit   Exit

Inline commands (typed in command mode, same shape as the CLI):
  list, status         Show runner status table
  local                List runners on this machine + per-runner metrics
  start NAME           Start a local runner
  stop NAME            Stop a local runner
  restart NAME         Restart a local runner
  logs NAME            Tail recent logs
  watch [SECONDS]      Auto-refresh status table (default 30s)
  notify               Send Telegram alert if any runner is offline
  add OWNER/REPO       Get registration token + setup instructions
  remove OWNER/REPO N  Deregister a runner from the repo

Aliases: l/ls=list · r=restart · s=start · x=stop · n=notify ·
         w=watch · a=add

Tip: bare `gh runner-status` opens the live dashboard. Pass a
subcommand for one-shot mode.
EOF
}

render_repl_banner() {
  local has_color="$1"
  local short_host
  short_host=${HOSTNAME%%.*}
  [[ -z "$short_host" ]] && short_host=$(hostname 2>/dev/null || echo "")
  local now
  now=$(date '+%H:%M:%S')
  local hsum
  hsum=$(host_summary)
  if [[ $has_color -eq 1 ]]; then
    printf '\033[1;36m▸ gh-runner-status\033[0m \033[2mv%s • %s • %s\033[0m\n' \
      "$VERSION" "${short_host:-localhost}" "$now"
    printf '\033[2m  %s\033[0m\n' "$hsum"
  else
    printf 'gh-runner-status v%s • %s • %s\n' "$VERSION" "${short_host:-localhost}" "$now"
    printf '  %s\n' "$hsum"
  fi
}

render_repl_footer() {
  local has_color="$1"
  local refresh="${2:-30}"
  if [[ $has_color -eq 1 ]]; then
    printf '\033[2m─ refreshing every %ss • \033[0m[r]\033[2mefresh \033[0m[c]\033[2mommand \033[0m[/]\033[2mslash \033[0m[a]\033[2mdd \033[0m[q]\033[2muit\033[0m\n' "$refresh"
  else
    printf -- '- refreshing every %ss • [r]efresh [c]ommand [/]slash [a]dd [q]uit\n' "$refresh"
  fi
}

# Render the active dashboard: banner, status table, footer. Used on
# REPL entry and on /clear so the user always has live state visible
# rather than a blank prompt.
render_dashboard() {
  local has_color="$1"
  local refresh="${2:-30}"
  if [[ $has_color -eq 1 ]]; then
    # Use the alternate screen? No — that hides scrollback. Just clear.
    printf '\033[H\033[2J' 2>/dev/null || true
  fi
  render_repl_banner "$has_color"
  echo

  local cfg="${CONFIG_FILE:-$(config_path)}"
  if [[ -f "$cfg" ]] && [[ -s "$cfg" ]]; then
    if ! dispatch_subcommand list 2>&1; then
      # shellcheck disable=SC2016 # backticks here are intentional literal text in the user-facing hint
      printf '\n\033[33m(could not fetch runner status — check `gh auth status` and try `list`)\033[0m\n'
    fi
  else
    cat <<EOF
no fleet configured yet. add one repo per line to:
  $cfg

press [a] to add a repo, or:
  mkdir -p $(dirname "$cfg")
  printf 'acme-corp/api\nacme-corp/web\n' > $cfg
EOF
  fi
  echo
  render_repl_footer "$has_color" "$refresh"
}

handle_repl_line() {
  local has_color="$1"; shift
  local line="$*"

  line="${line#"${line%%[![:space:]]*}"}"
  line="${line%"${line##*[![:space:]]}"}"
  [[ -z "$line" ]] && return 0
  history -s -- "$line" 2>/dev/null || true

  case "$line" in
    /help|/?|help|"?")
      repl_help
      ;;
    /quit|/exit|exit|quit)
      DASHBOARD_QUIT=1
      ;;
    /clear|clear)
      # The dashboard loop redraws after every command anyway, so this
      # is effectively a no-op slash that returns to the dashboard.
      :
      ;;
    /repos)
      local f="${CONFIG_FILE:-$(config_path)}"
      if [[ -f "$f" ]]; then
        echo "# $f"; cat "$f"
      else
        echo "(no config file at $f — type \`add OWNER/REPO\` to create it)"
      fi
      ;;
    /*)
      echo "unknown slash command: $line"
      echo "type /help"
      ;;
    *)
      local words=()
      while IFS= read -r w; do
        [[ -n "$w" ]] && words+=("$w")
      done < <(printf '%s' "$line" | xargs -n 1 printf '%s\n' 2>/dev/null || printf '%s' "$line")
      [[ ${#words[@]} -eq 0 ]] && return 0

      local first="${words[0]}"
      case "$first" in
        l|ls) words[0]="list" ;;
        r)    words[0]="restart" ;;
        s)    words[0]="start" ;;
        x)    words[0]="stop" ;;
        n)    words[0]="notify" ;;
        w)    words[0]="watch" ;;
        a)    words[0]="add" ;;
      esac
      case "${words[0]}" in
        list|status|local|start|stop|restart|logs|notify|watch|add|remove)
          dispatch_subcommand "${words[@]}" || true
          ;;
        *)
          dispatch_subcommand list "${words[@]}" || true
          ;;
      esac
      ;;
  esac
}

# Drop into a single-line command prompt below the dashboard.
# Optional second arg pre-fills the input line (used by the [/] and
# [a] dashboard shortcuts to give the user a head start). Returns to
# the dashboard after the command runs.
prompt_and_run() {
  local has_color="$1"
  local prefill="${2:-}"
  local prompt
  if [[ $has_color -eq 1 ]]; then
    prompt=$'\001\033[36m\002❯\001\033[0m\002 '
  else
    prompt='> '
  fi
  echo
  local line
  # `read -e -i <text>` pre-fills the readline buffer with <text>, so
  # the user sees `❯ /` or `❯ add ` and can type the rest. Falls back
  # to plain prompt if -i is unsupported (older bash).
  if [[ -n "$prefill" ]]; then
    if ! IFS= read -r -e -i "$prefill" -p "$prompt" line 2>/dev/null; then
      echo
      return 0
    fi
  else
    if ! IFS= read -r -e -p "$prompt" line; then
      echo
      return 0
    fi
  fi
  echo
  handle_repl_line "$has_color" "$line"
  if [[ $has_color -eq 1 ]]; then
    printf '\n\033[2m── press any key to return to the dashboard ──\033[0m'
  else
    printf '\n-- press any key to return to the dashboard --'
  fi
  read -rsn 1 _ 2>/dev/null
  printf '\n'
}

# The active monitoring loop: dashboard + key handler. Refreshes every
# REFRESH seconds (default 30). Single-key controls below the dashboard.
dashboard_loop() {
  local refresh="${1:-30}"
  local has_color=0
  [[ -t 1 ]] && has_color=1
  DASHBOARD_QUIT=0

  # Ctrl-C exits gracefully (default would kill the script with 130 and
  # leave the terminal in a weird state).
  trap 'echo; DASHBOARD_QUIT=1' INT

  while [[ $DASHBOARD_QUIT -eq 0 ]]; do
    render_dashboard "$has_color" "$refresh"

    local key="" rc=0
    # Silent, single-char read with a timeout. Timeout → redraw with
    # fresh data. Keypress → handle. EOF (Ctrl-D, closed stdin) returns
    # non-zero with empty key — distinguish from a timeout via $rc.
    read -rsn 1 -t "$refresh" key
    rc=$?

    # rc=0: got a key. rc=142 (timeout). rc=1+: EOF/error.
    if [[ $rc -gt 1 ]]; then
      DASHBOARD_QUIT=1
      continue
    fi

    case "$key" in
      q|Q) DASHBOARD_QUIT=1 ;;
      r|R) ;; # fall through, loop redraws
      h|H|"?")
        repl_help
        printf '\nPress any key...'
        read -rsn 1 _ 2>/dev/null
        printf '\n'
        ;;
      c|C) prompt_and_run "$has_color" ;;
      /)   prompt_and_run "$has_color" "/" ;;     # pre-fill slash
      a|A) prompt_and_run "$has_color" "add " ;;  # pre-fill add command
      "")  ;; # timeout, just redraw
      *)   ;; # ignore other keys
    esac
  done

  trap - INT
  if [[ $has_color -eq 1 ]]; then
    printf '\033[2mbye!\033[0m\n'
  else
    echo "bye!"
  fi
}

interactive_mode() {
  dashboard_loop 30
}

# ---------------------------------------------------------------------------
# Main
# ---------------------------------------------------------------------------

main() {
  require gh
  require jq

  CONFIG_FILE=$(config_path)
  JSON_OUTPUT=0
  local subcommand=""
  local positional=()

  # Parse flags first; allow them anywhere
  local args=()
  while [[ $# -gt 0 ]]; do
    case "$1" in
      -h|--help) usage; exit 0 ;;
      --version) echo "gh-runner-status $VERSION"; exit 0 ;;
      --json) JSON_OUTPUT=1; shift ;;
      --config)
        if [[ $# -lt 2 ]]; then
          echo "error: --config requires a value" >&2
          exit 2
        fi
        CONFIG_FILE="$2"; shift 2 ;;
      --config=*) CONFIG_FILE="${1#--config=}"; shift ;;
      --threshold)
        if [[ $# -lt 2 || ! "$2" =~ ^[0-9]+$ ]]; then
          echo "error: --threshold requires a non-negative integer" >&2
          exit 2
        fi
        NOTIFY_THRESHOLD="$2"; shift 2 ;;
      --threshold=*)
        NOTIFY_THRESHOLD="${1#--threshold=}"
        if [[ ! "$NOTIFY_THRESHOLD" =~ ^[0-9]+$ ]]; then
          echo "error: --threshold requires a non-negative integer" >&2
          exit 2
        fi
        shift ;;
      --) shift; while [[ $# -gt 0 ]]; do args+=("$1"); shift; done ;;
      -*) echo "error: unknown option '$1'" >&2; exit 2 ;;
      *) args+=("$1"); shift ;;
    esac
  done

  # First non-flag arg may be a subcommand. If there's no arg AND stdin
  # is a TTY, drop into the REPL — that's the "just like Claude Code"
  # interactive experience. Non-TTY (cron, pipes) defaults to `list`
  # so existing scripts keep working.
  if [[ ${#args[@]} -eq 0 ]]; then
    if [[ -t 0 && -t 1 ]]; then
      interactive_mode
      exit 0
    fi
    subcommand="list"
  else
    case "${args[0]}" in
      list|status|local|start|stop|restart|logs|notify|watch|add|remove)
        subcommand="${args[0]}"
        positional=("${args[@]:1}")
        ;;
      *)
        subcommand="list"
        positional=("${args[@]}")
        ;;
    esac
  fi

  # macOS bash 3.2 errors on `"${empty[@]}"` under set -u; ${var:+...}
  # makes the expansion safe whether positional is empty or populated.
  dispatch_subcommand "$subcommand" ${positional[@]:+"${positional[@]}"}
  local rc=$?
  # Surface validation/usage errors as exit 2 (matches CLI norms);
  # other non-zero returns become exit 1.
  if [[ $rc -ne 0 ]]; then
    exit 2
  fi
  exit 0
}

# Guard so test files can source the script for unit-testing functions
# without triggering the full CLI execution.
if [[ -z "${GH_RUNNER_STATUS_NO_MAIN:-}" ]]; then
  main "$@"
fi
